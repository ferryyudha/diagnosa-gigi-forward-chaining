# =====================================================
# SIPAGI - TEMPLATE KONFIGURASI (.env.example)
# =====================================================
# CARA PAKAI:
#   1. Salin file ini menjadi .env
#      (copy .env.example .env)
#   2. Isi nilai yang sesuai dengan server Anda
#   3. File .env TIDAK boleh di-commit ke Git!
# =====================================================

# -----------------------------------------------
# KONFIGURASI DATABASE
# Sesuaikan dengan pengaturan MySQL Anda
# -----------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_gigi
DB_USER=root
DB_PASS=

# -----------------------------------------------
# KONFIGURASI APLIKASI
# Ubah APP_URL sesuai lokasi install Anda
# -----------------------------------------------
APP_NAME=SiPaGi
APP_URL=http://localhost/forward_chaining
APP_ENV=development
# APP_ENV: "development" (tampilkan error detail)
#          "production"  (sembunyikan error detail)

# -----------------------------------------------
# KONFIGURASI SESSION
# -----------------------------------------------
SESSION_NAME=sipagi_session
SESSION_LIFETIME=7200

# -----------------------------------------------
# INFO KLINIK (tampil di footer & print)
# -----------------------------------------------
KLINIK_NAMA=Praktik Mandiri Drg. Hj. Rini Sutarti
KLINIK_ALAMAT=Jl. Contoh No. 1, Kota Anda
KLINIK_TELP=08xx-xxxx-xxxx
